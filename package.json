{
  "name": "@leaflet-custom/map-with-labels",
  "version": "1.0.0",
  "description": "Leaflet plugin for high-performance canvas labels with priority and styles",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc --noEmit",
    "start:exampleJS": "http-server . -p 8080"
  },
  "peerDependencies": {
    "leaflet": "^1.9.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "http-server": "^14.1.1",
    "leaflet": "^1.9.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
